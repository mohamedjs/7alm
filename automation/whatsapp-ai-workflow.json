    {
      "parameters": {
        "jsCode": "const CREDIT_RE = /(^|[^0-9])402([^0-9]|$)|credit|quota|insufficient|payment|billing|exceeded/;\nconst MSG = {\n  credit: 'معلش يا فندم، الخدمة عندنا واقفة مؤقتًا 🙏 هنرجع نرد عليك في أقرب وقت.',\n  transient: 'حصل خلل بسيط عندنا دلوقتي، ممكن تبعت رسالتك تاني بعد شوية؟ 🙏'\n};\nlet items = [];\ntry { items = $input.all(); } catch (e) { items = []; }\nif (!items.length) items = [{ json: {} }];\nreturn items.map((item) => {\n  let failureClass = 'transient';\n  let haystack = '';\n  try { haystack += JSON.stringify(item.json ?? {}); } catch (e) {}\n  try { haystack += ' ' + JSON.stringify(item.error ?? {}); } catch (e) {}\n  try { if (CREDIT_RE.test(haystack.toLowerCase())) failureClass = 'credit'; } catch (e) {}\n  return { json: { output: MSG[failureClass], aiFailed: true, failureClass } };\n});\n"
      },
